[gd_scene format=3]

[ext_resource type="Script" path="res://UI/level_up_ui.gd" id="1_lui"]

[node name="LevelUpUI" type="CanvasLayer"]
process_mode = 3
script = ExtResource("1_lui")

[node name="BackgroundDim" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.65)

[node name="CenterContainer" type="CenterContainer" parent="BackgroundDim"]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBoxContainer" type="VBoxContainer" parent="BackgroundDim/CenterContainer"]
theme_override_constants/separation = 24

[node name="TitleLabel" type="Label" parent="BackgroundDim/CenterContainer/VBoxContainer"]
text = "Level Up! Each player, choose your power-up:"
theme_override_font_sizes/font_size = 26
horizontal_alignment = 1

[node name="PlayersHBox" type="HBoxContainer" parent="BackgroundDim/CenterContainer/VBoxContainer"]
theme_override_constants/separation = 32

[node name="P1Section" type="VBoxContainer" parent="BackgroundDim/CenterContainer/VBoxContainer/PlayersHBox"]
theme_override_constants/separation = 12

[node name="P1HeaderLabel" type="Label" parent="BackgroundDim/CenterContainer/VBoxContainer/PlayersHBox/P1Section"]
text = "Player 1  (Mouse to click)"
theme_override_font_sizes/font_size = 18
horizontal_alignment = 1

[node name="CardsContainerP1" type="HBoxContainer" parent="BackgroundDim/CenterContainer/VBoxContainer/PlayersHBox/P1Section"]
theme_override_constants/separation = 20

[node name="VSeparator" type="VSeparator" parent="BackgroundDim/CenterContainer/VBoxContainer/PlayersHBox"]

[node name="P2Section" type="VBoxContainer" parent="BackgroundDim/CenterContainer/VBoxContainer/PlayersHBox"]
theme_override_constants/separation = 12

[node name="P2HeaderLabel" type="Label" parent="BackgroundDim/CenterContainer/VBoxContainer/PlayersHBox/P2Section"]
text = "Player 2  (D-Pad to navigate, A to confirm)"
theme_override_font_sizes/font_size = 18
horizontal_alignment = 1

[node name="CardsContainerP2" type="HBoxContainer" parent="BackgroundDim/CenterContainer/VBoxContainer/PlayersHBox/P2Section"]
theme_override_constants/separation = 20
